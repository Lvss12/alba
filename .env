SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"

# Use a dedicated Sepolia account for deployment (can be same as prover)
DEPLOYER_PRIVATE_KEY="0x..."

# Two participant accounts that will lock funds and sign state updates
PROVER_PRIVATE_KEY="0x..."
VERIFIER_PRIVATE_KEY="0x..."

# (Optional) If you deploy a new contract, the scripts will print the address.
# If you want to re-use an existing deployment, set this and skip deploy.
ALBA_ADDRESS=""

